{
  "name": "flowstack-sdk",
  "version": "0.2.1",
  "description": "Complete Backend-as-a-Service SDK for building AI-powered apps with zero backend code",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./api": {
      "types": "./dist/api/index.d.ts",
      "import": "./dist/api/index.mjs",
      "require": "./dist/api/index.js"
    },
    "./wallet": {
      "types": "./dist/wallet/index.d.ts",
      "import": "./dist/wallet/index.mjs",
      "require": "./dist/wallet/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup src/index.ts src/api/index.ts --format cjs,esm --dts --watch",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@privy-io/react-auth": ">=2.0.0",
    "@privy-io/wagmi": ">=1.0.0",
    "@tanstack/react-query": ">=5.0.0",
    "next": ">=14.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "viem": ">=2.0.0",
    "wagmi": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "@privy-io/react-auth": {
      "optional": true
    },
    "@privy-io/wagmi": {
      "optional": true
    },
    "wagmi": {
      "optional": true
    },
    "viem": {
      "optional": true
    },
    "@tanstack/react-query": {
      "optional": true
    }
  },
  "dependencies": {
    "jsonwebtoken": "^9.0.2",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@privy-io/react-auth": "^2.0.0",
    "@privy-io/wagmi": "^1.0.0",
    "@tanstack/react-query": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "next": "^14.2.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^3.0.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.0",
    "viem": "^2.0.0",
    "vitest": "^4.1.2",
    "wagmi": "^2.0.0"
  },
  "keywords": [
    "flowstack",
    "sdk",
    "react",
    "nextjs",
    "ai",
    "agent",
    "auth",
    "storage",
    "backend-as-a-service"
  ],
  "author": "Flowstack",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/flowstack-fun/flowstack-sdk"
  },
  "homepage": "https://flowstack.fun",
  "bugs": {
    "url": "https://github.com/flowstack-fun/flowstack-sdk/issues"
  }
}
